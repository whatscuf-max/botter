# ═══════════════════════════════════════════════════════════
# Polymarket Bot Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ─── Wallet Configuration ─────────────────────────────────
# Your Polygon wallet private key (WITHOUT 0x prefix)
# NEVER share this with anyone!
POLYMARKET_PK=your_private_key_here

# Your wallet's public address (for proxy/email wallets)
# Leave empty for standard EOA wallets
POLYMARKET_FUNDER=

# Signature type: 0=EOA, 1=email/Magic, 2=Gnosis Safe
POLYMARKET_SIG_TYPE=0

# ─── Trading Configuration ────────────────────────────────
# Starting balance in USDC
STARTING_BALANCE=50

# Set to "false" for live trading (CAUTION!)
DRY_RUN=true

# ─── Optional: Telegram Notifications ─────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
