# ================================================================
# Kalshi Weather Trading Bot Configuration
# Copy this file to .env and fill in your values
# NEVER commit your .env or private key to version control!
# ================================================================

# --- Kalshi API Credentials -------------------------------------------
# Your API Key ID from https://kalshi.com/account/profile/api
KALSHI_API_KEY_ID=your-api-key-id-here

# Path to your RSA private key file (the ~1600-char PEM file from Kalshi)
KALSHI_PRIVATE_KEY_PATH=kalshi_private_key.pem

# Use Kalshi demo environment? (true = paper trading on demo-api.kalshi.co)
KALSHI_USE_DEMO=true

# --- Trading Configuration --------------------------------------------
# Starting balance in USD
STARTING_BALANCE=50

# Set to false for live trading (CAUTION!)
DRY_RUN=true

# --- Optional: Telegram Notifications ---------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
